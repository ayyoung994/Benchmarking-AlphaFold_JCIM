; ions.mdp  — short EM to prepare ions.tpr
integrator      = steep
nsteps          = 5000          ; fine — genion won’t actually run MD
emtol           = 1000.0
emstep          = 0.01

; Nonbonded model (CHARMM36/TIP3P style)
cutoff-scheme   = Verlet
nstlist         = 20
coulombtype     = PME
rcoulomb        = 1.2
vdwtype         = switch
rvdw-switch     = 1.0
rvdw            = 1.2
pbc             = xyz

; Keep it simple for EM
constraints     = none